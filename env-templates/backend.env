# ===========================================
# PadmaVue.ai Backend Configuration
# ===========================================
# Copy this file to backend/.env

# ==========================================
# Application Settings
# ==========================================
APP_NAME=PadmaVue.ai
DEBUG=true
LOG_LEVEL=INFO

# Security (CHANGE IN PRODUCTION!)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-secret-key-change-in-production

# Optional API key authentication
# API_KEY=your-secure-api-key

# ==========================================
# Storage Mode
# ==========================================
# lite  = Local file storage only (default, no external databases)
# full  = Neo4j + Qdrant (requires Docker or external services)
STORAGE_MODE=lite

# ==========================================
# API Configuration
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# Storage Configuration (Persistent)
# ==========================================
DATA_DIR=./data
LOG_DIR=./logs
UPLOAD_DIR=./uploads

# ==========================================
# Logging Configuration
# ==========================================
LOG_TO_FILE=true
LOG_MAX_SIZE_MB=10
LOG_RETENTION_DAYS=30

# ==========================================
# LLM Provider Configuration
# ==========================================
# Options: mock, ollama, lmstudio, openai, anthropic, openrouter, gemini, vertex, bedrock
LLM_PROVIDER=mock

# Ollama Configuration (Local LLM - Recommended)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Run: ollama pull llama3.2 && ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LM Studio Configuration (Local LLM)
# Download: https://lmstudio.ai
# Start the local server (default port: 1234)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=  # Leave empty for default model

# OpenAI Configuration
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic / Claude Configuration
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenRouter Configuration (access multiple models)
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Google Gemini Configuration
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_MODEL=gemini-1.5-pro

# AWS Bedrock Configuration
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ==========================================
# Web Search Configuration (Grounded Responses)
# ==========================================
# Enable web search for fact-checked AI responses with citations
# Options: none, searxng, tavily, serper, brave, bing, mock
# Recommended: searxng (open-source, self-hosted, privacy-focused)
SEARCH_PROVIDER=none

# SearXNG Configuration (Open Source - RECOMMENDED)
# Start with: docker compose -f infra/docker/compose/docker-compose.search.yml up -d
SEARXNG_BASE_URL=http://localhost:8080

# Paid Provider API Keys (optional, choose one)
# TAVILY_API_KEY=tvly-your-key     # https://tavily.com
# SERPER_API_KEY=your-key          # https://serper.dev
# BRAVE_API_KEY=BSA-your-key       # https://brave.com/search/api
# BING_API_KEY=your-key            # https://azure.microsoft.com/cognitive-services/bing-web-search-api
# SEARCH_API_KEY=your-generic-key  # Fallback for any provider

# Maximum search results to return (default: 5)
# SEARCH_MAX_RESULTS=5

# ==========================================
# Thinking Time / Reasoning Configuration
# ==========================================
# Controls how deeply the AI reasons before responding
# Options: fast, balanced, deep (default: balanced)
REASONING_LEVEL=balanced

# Show concise reasoning summary (key steps, assumptions, evidence)
# Does NOT expose raw chain-of-thought
SHOW_REASONING_SUMMARY=true

# ==========================================
# Embeddings Configuration
# ==========================================
EMBEDDING_PROVIDER=mock
# EMBEDDING_MODEL=text-embedding-3-small

# ==========================================
# Database Configuration (Full Mode Only)
# ==========================================
# These are only used when STORAGE_MODE=full

# Neo4j (GraphRAG)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=padmavue

# Qdrant (Vector RAG)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=security_documents
# QDRANT_API_KEY=your-qdrant-api-key

# ==========================================
# File Upload Settings
# ==========================================
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.md,.txt,.json,.yaml,.yml,.xml,.py,.js,.ts,.tf

# ===========================================
# PadmaVue.ai .gitignore
# ===========================================

# ==========================================
# Secrets & Credentials (CRITICAL)
# ==========================================
.env
.env.*
!.env.example
*.env
!env-templates/*.env
backend/.env
frontend/.env
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks
*.keystore
credentials*
secrets*
*.secret
service-account*.json
*-credentials.json
.htpasswd
.netrc

# API keys / tokens that may be saved locally
llm-config.json
mcp-config.json
.env.configured
*.env.configured

# ==========================================
# Runtime Data (user uploads, analysis data)
# ==========================================
data/
logs/
uploads/
backend/data/
backend/logs/
backend/uploads/
backend/temp/
/tmp/

# ==========================================
# Python
# ==========================================
backend/venv/
venv/
env/
.venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
backend/.pytest_cache/
*.egg-info/
dist/
build/
*.egg
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ==========================================
# Node / Frontend
# ==========================================
frontend/node_modules/
node_modules/
frontend/.next/
frontend/out/
frontend/public/generated/
frontend/tsconfig.tsbuildinfo
*.tsbuildinfo
.turbo/

# ==========================================
# IDE & Editor
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ==========================================
# OS Files
# ==========================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
*.lnk

# ==========================================
# Process IDs
# ==========================================
.pid
*.pid
.*.pid
pids/
*.seed

# ==========================================
# Logs
# ==========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# Docker Data Volumes
# ==========================================
infra/docker/compose/searxng-data/
**/searxng-data/
docker-compose.override.yml

# ==========================================
# Tool-specific (Snyk, DeepCode, etc.)
# ==========================================
.snyk
.dcignore
.scannerwork/

# ==========================================
# Test & Debug Artifacts
# ==========================================
test_*.py
!tests/**/test_*.py
!backend/tests/**/test_*.py

# ==========================================
# AI Assistant / Cursor / Claude
# ==========================================
.claude/
.cursor/
.codex/
.aider*

# ==========================================
# Temporary documentation (session artifacts)
# ==========================================
BUGFIX_*.md
IMPLEMENTATION_*.md
*_SCHEMA.md
TODO.md
NOTES.md
